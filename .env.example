# -----------------------------------------------------------------------------
# Pjozz Technologies — environment template
# Copy to `.env.local` and fill in values. Never commit secrets.
# -----------------------------------------------------------------------------

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public origins
# Local / preview:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production canonical (SEO, OG, sitemap, proposal share links in emails):
NEXT_PUBLIC_SITE_URL=https://pjozz.co.za
# On Vercel production also set NEXT_PUBLIC_APP_URL=https://pjozz.co.za

# Public contact (marketing site footer, WhatsApp FAB, contact page)
NEXT_PUBLIC_WHATSAPP_E164=27751668800
NEXT_PUBLIC_HELLO_EMAIL=pgpjoz@gmail.com
NEXT_PUBLIC_PHONE_TEL=tel:+27751668800
# NEXT_PUBLIC_TWITTER_HANDLE=@pjozz
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=pjozz.co.za

# Ops notifications (inbound forms, proposal accept / change requests)
OPS_NOTIFY_EMAIL=pgpjoz@gmail.com
# PJozZ_TEAM_EMAIL=pgpjoz@gmail.com

# --- Admin console sign-in (REQUIRED in production) ---
# Use a strong unique password — anyone with this value has full operator access.
ADMIN_PASSWORD=
# HMAC key for the admin session cookie (>= 16 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_SESSION_SECRET=

# Anthropic (AI scoring, briefs, proposals, chat)
ANTHROPIC_API_KEY=

# Resend (email) — for production, verify pjozz.co.za in Resend and use that domain
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# EMAIL_FROM=  # optional alias

# Google Custom Search (lead web discovery)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# n8n automation (either base URL name works)
N8N_BASE_URL=http://localhost:5678
# N8N_WEBHOOK_BASE_URL=http://localhost:5678  # legacy alias
N8N_INBOUND_SECRET=
N8N_WEBHOOK_CALL_SECRET=
OUTREACH_CRON_SECRET=

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
# TWILIO_WEBHOOK_PUBLIC_URL=
# TWILIO_VALIDATE_WEBHOOK=true
