# -----------------------------------------------------------------------------
# Pjozz Technologies — environment template
# Copy to `.env.local` and fill in values. Never commit secrets.
# -----------------------------------------------------------------------------

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public app origin (tracking pixels, proposal share links, Twilio webhook fallback)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Preferred canonical URL for SEO / OG / sitemap (falls back to NEXT_PUBLIC_APP_URL)
# NEXT_PUBLIC_SITE_URL=https://pjozz.co.za

# Public contact (marketing site)
# NEXT_PUBLIC_WHATSAPP_E164=27791234567
# NEXT_PUBLIC_HELLO_EMAIL=hello@pjozz.co.za
# NEXT_PUBLIC_PHONE_TEL=tel:+27123456789
# NEXT_PUBLIC_TWITTER_HANDLE=@pjozz
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=pjozz.co.za

# Ops notifications (proposal accept / change requests / inbound forms)
# OPS_NOTIFY_EMAIL=team@pjozz.co.za
# PJozZ_TEAM_EMAIL=team@pjozz.co.za

# --- Admin console sign-in ---
# Password required to enter the operator console. Change to a strong secret
# in production; anyone with this value has full admin access.
ADMIN_PASSWORD=
# HMAC key used to sign the admin session cookie. MUST be >= 16 chars — use a
# random 32+ byte value (e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"`).
ADMIN_SESSION_SECRET=

# Anthropic (AI scoring, briefs, proposals, chat)
ANTHROPIC_API_KEY=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# EMAIL_FROM=  # optional alias

# Google Custom Search (lead web discovery)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# n8n automation (either base URL name works)
N8N_BASE_URL=http://localhost:5678
# N8N_WEBHOOK_BASE_URL=http://localhost:5678  # legacy alias
N8N_INBOUND_SECRET=
N8N_WEBHOOK_CALL_SECRET=
OUTREACH_CRON_SECRET=

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
# TWILIO_WEBHOOK_PUBLIC_URL=
# TWILIO_VALIDATE_WEBHOOK=true
